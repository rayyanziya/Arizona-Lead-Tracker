# ─────────────────────────────────────────────────────────────────────────
# Arizona Lead Tracker — environment template
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────

# --- App ---
APP_ENV=development            # development | staging | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-long-random-string      # JWT signing
# Fernet key for encrypting platform session blobs at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=change-me-32-url-safe-base64-bytes

# --- Postgres ---
POSTGRES_USER=alt
POSTGRES_PASSWORD=alt_password
POSTGRES_DB=arizona_lead_tracker
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Async DSN (FastAPI) and sync DSN (Celery/Alembic) are derived in config.py

# --- Redis (Celery broker + dedup cache) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- Anthropic (Claude scoring) ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5            # claude-haiku-4-5 | claude-sonnet-4-6
CLAUDE_SCORE_THRESHOLD=7                 # default tenant notify threshold (1-10)

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Default chat id used by the seeded MVP tenant (your personal chat/channel)
TELEGRAM_DEFAULT_CHAT_ID=

# --- Email (SMTP) ---
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=leads@arizona-tracker.local
SMTP_USE_TLS=false

# --- Reddit (PRAW) — Phase 4 ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=arizona-lead-tracker/0.1 by u/yourname

# --- Browser automation (Facebook / X) — Phase 3/5 ---
# Path (inside the browser worker container) to the encrypted storage_state dir
BROWSER_SESSION_DIR=/app/.sessions
BROWSER_HEADLESS=true
BROWSER_LOCALE=id-ID
BROWSER_TIMEZONE=Asia/Jakarta
# Optional outbound proxy for scraping workers (residential/mobile recommended)
BROWSER_PROXY_SERVER=
BROWSER_PROXY_USERNAME=
BROWSER_PROXY_PASSWORD=

# --- Scraping cadence / anti-ban ---
SCRAPE_INTERVAL_SECONDS=1200             # base interval between scrapes (20 min)
SCRAPE_JITTER_SECONDS=600                # +/- random jitter added per run
SCRAPE_MIN_DELAY_MS=2500                 # min human-like delay between actions
SCRAPE_MAX_DELAY_MS=7000                 # max human-like delay between actions
SCRAPE_MAX_POSTS_PER_RUN=40              # cap posts pulled per source per run
