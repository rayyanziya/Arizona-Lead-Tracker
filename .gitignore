node_modules/
frontend/dist/
frontend/.vite/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.log
*~
*.bak
*.tmp

# Databases (local/dev SQLite — never commit data)
*.sqlite
*.sqlite3
*.db

# Celery / Redis runtime artifacts (when run outside Docker)
celerybeat-schedule*
celerybeat.pid
*.pid
dump.rdb
appendonlydir/

# Playwright test artifacts
playwright-report/
test-results/
.playwright/

# Python build artifacts
build/
dist/
